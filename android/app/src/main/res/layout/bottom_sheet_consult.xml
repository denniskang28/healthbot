<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How would you like to consult?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAiConsult"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:text="🤖 AI Consultation"
        android:visibility="gone"
        android:backgroundTint="#7B1FA2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDoctorConsult"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:text="👨‍⚕️ Online Doctor Consultation"
        android:visibility="gone"
        android:backgroundTint="@color/secondary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAppointment"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:text="🏥 Book Hospital Appointment"
        android:visibility="gone"
        android:backgroundTint="@color/accent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLater"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Maybe Later"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textColor="@color/text_secondary" />
</LinearLayout>
